<template>
  <van-popup
    v-model:show="visible"
    position="bottom"
    :style="{ height: '100%' }"
    teleport="body"
  >
    <div class="a4-camera-guide">
      <!-- 顶部工具栏 -->
      <div class="camera-header">
        <van-icon name="cross" size="24" @click="closeCamera" />
        <span class="title">{{ previewMode ? '照片预览' : '拍照引导' }}</span>
        <van-icon v-if="previewMode" name="replay" size="24" @click="retakePhoto" />
        <span v-else class="header-placeholder"></span>
      </div>
      
      <!-- 拍照引导界面 -->
      <template v-if="!previewMode">
        <div class="guide-instructions">
          <div class="instruction-item">
            <van-icon name="photo-o" size="20" />
            <span>1. 将作业平铺在桌面上</span>
          </div>
          <div class="instruction-item">
            <van-icon name="aim" size="20" />
            <span>2. 确保作业在框内显示完整</span>
          </div>
          <div class="instruction-item">
            <van-icon name="light" size="20" />
            <span>3. 保持光线充足，避免阴影</span>
          </div>
        </div>
        
        <div class="a4-guide-example">
          <div class="a4-frame-example">
            <div class="corner corner-tl"></div>
            <div class="corner corner-tr"></div>
            <div class="corner corner-bl"></div>
            <div class="corner corner-br"></div>
            <div class="a4-label">A4</div>
          </div>
          <p class="example-tip">拍摄时请对齐A4参考框</p>
        </div>
        
        <div class="camera-controls">
          <div class="button-group">
            <van-button type="primary" size="large" icon="photograph" @click="takePhoto">
              开始拍照
            </van-button>
            <van-button type="default" size="large" @click="openFilePicker">
              从相册选择
            </van-button>
          </div>
          <p class="photo-tip">建议使用系统相机拍摄，确保照片清晰</p>
        </div>
      </template>
      
      <!-- 照片预览界面 -->
      <template v-else>
        <div class="preview-container">
          <div class="a4-preview-wrapper">
            <div class="a4-frame-container" :style="a4FrameStyle">
              <img :src="previewUrl" class="preview-image" @load="onPreviewLoad" ref="previewImageRef" />
              <div class="a4-frame-overlay">
                <div class="corner corner-tl"></div>
                <div class="corner corner-tr"></div>
                <div class="corner corner-bl"></div>
                <div class="corner corner-br"></div>
                <div class="a4-label">A4参考框</div>
              </div>
              
              <!-- 检测结果标签 -->
              <div class="detection-results" v-if="detectionCompleted">
                <div class="result-tag" :class="detectionResults.clarity.pass ? 'pass' : 'fail'">
                  {{ detectionResults.clarity.pass ? '✓ 清晰' : '✗ 模糊' }}
                </div>
                <div class="result-tag" :class="detectionResults.angle.pass ? 'pass' : 'fail'">
                  {{ detectionResults.angle.pass ? '✓ 角度正常' : '✗ 歪斜 ' + detectionResults.angle.value.toFixed(1) + '°' }}
                </div>
                <div class="result-tag" :class="detectionResults.text.pass ? 'pass' : 'fail'">
                  {{ detectionResults.text.pass ? '✓ 包含文字' : '✗ 无文字内容' }}
                </div>
                <div class="result-tag" :class="detectionResults.material.pass ? 'pass' : 'fail'">
                  {{ detectionResults.material.pass ? '✓ 学习资料' : '✗ 非学习资料' }}
                </div>
              </div>
            </div>
          </div>
          
          <!-- 检测状态 -->
          <div class="quality-status" v-if="detecting">
            <van-loading size="20" />
            <span>正在检测照片...</span>
          </div>
          
          <div class="preview-tips" v-if="detectionCompleted">
            <van-icon name="info-o" />
            <span>{{ allPassed ? '照片检测通过，可以使用' : '检测发现问题，建议重拍' }}</span>
          </div>
          
          <div class="preview-actions">
            <van-button type="default" size="large" @click="retakePhoto">重新拍摄</van-button>
            <van-button type="primary" size="large" @click="handleConfirmClick" :disabled="detecting">
              {{ allPassed ? '使用此照片' : '继续使用' }}
            </van-button>
          </div>
        </div>
      </template>
      
      <!-- 隐藏的文件输入框 -->
      <input ref="cameraInputRef" type="file" accept="image/*" capture="environment" style="display: none" @change="handleFileSelect" />
      <input ref="albumInputRef" type="file" accept="image/*" style="display: none" @change="handleFileSelect" />
    </div>
    
    <!-- 检测问题弹窗 -->
    <van-dialog
      v-model:show="showProblemDialog"
      title="照片检测问题"
      :message="problemMessage"
      show-cancel-button
      confirm-button-text="继续使用"
      cancel-button-text="重新拍摄"
      @confirm="confirmUsePhoto"
      @cancel="retakePhoto"
    />
  </van-popup>
</template>

<script setup lang="ts">
import { ref, computed, watch } from 'vue'
import { showToast } from 'vant'

interface Props {
  modelValue: boolean
  maxCount?: number
}

const props = withDefaults(defineProps<Props>(), {
  modelValue: false,
  maxCount: 9
})

const emit = defineEmits<{
  'update:modelValue': [value: boolean]
  'capture': [file: File]
  'error': [error: Error]
}>()

const cameraInputRef = ref<HTMLInputElement | null>(null)
const albumInputRef = ref<HTMLInputElement | null>(null)
const previewImageRef = ref<HTMLImageElement | null>(null)

const visible = ref(false)
const previewMode = ref(false)
const previewUrl = ref('')
const selectedFile = ref<File | null>(null)
const detecting = ref(false)
const detectionCompleted = ref(false)
const showProblemDialog = ref(false)

// 四项检测结果
const detectionResults = ref({
  clarity: { pass: true, value: 0 },
  angle: { pass: true, value: 0 },
  text: { pass: true, value: 0 },
  material: { pass: true, value: 0, whiteRatio: 0, colorCount: 0 }
})

const a4FrameStyle = computed(() => ({ aspectRatio: '210 / 297' }))

const allPassed = computed(() => {
  return detectionResults.value.clarity.pass &&
         detectionResults.value.angle.pass &&
         detectionResults.value.text.pass &&
         detectionResults.value.material.pass
})

const problemMessage = computed(() => {
  const problems: string[] = []
  if (!detectionResults.value.clarity.pass) problems.push('照片模糊')
  if (!detectionResults.value.angle.pass) problems.push(`照片歪斜 ${detectionResults.value.angle.value.toFixed(1)}°`)
  if (!detectionResults.value.text.pass) problems.push('未检测到文字内容')
  if (!detectionResults.value.material.pass) problems.push('可能不是学习资料')
  return '检测到以下问题：' + problems.join('、') + '。是否继续使用？'
})

function resetState() {
  previewMode.value = false
  if (previewUrl.value) URL.revokeObjectURL(previewUrl.value)
  previewUrl.value = ''
  selectedFile.value = null
  detecting.value = false
  detectionCompleted.value = false
  showProblemDialog.value = false
  detectionResults.value = {
    clarity: { pass: true, value: 0 },
    angle: { pass: true, value: 0 },
    text: { pass: true, value: 0 },
    material: { pass: true, value: 0, whiteRatio: 0, colorCount: 0 }
  }
}

function takePhoto() {
  if (cameraInputRef.value) {
    cameraInputRef.value.value = ''
    cameraInputRef.value.click()
  }
}

function openFilePicker() {
  if (albumInputRef.value) {
    albumInputRef.value.value = ''
    albumInputRef.value.click()
  }
}

async function handleFileSelect(event: Event) {
  const input = event.target as HTMLInputElement
  const file = input.files?.[0]
  if (!file) return
  
  try {
    const compressedFile = await compressImage(file)
    selectedFile.value = compressedFile
    previewUrl.value = URL.createObjectURL(compressedFile)
    previewMode.value = true
    detectionCompleted.value = false
  } catch (error) {
    console.error('图片压缩失败:', error)
    selectedFile.value = file
    previewUrl.value = URL.createObjectURL(file)
    previewMode.value = true
  }
}

async function compressImage(file: File): Promise<File> {
  return new Promise((resolve, reject) => {
    const reader = new FileReader()
    reader.onload = (e) => {
      const img = new Image()
      img.onload = () => {
        const canvas = document.createElement('canvas')
        const maxWidth = 1200
        const scale = maxWidth / img.width
        canvas.width = maxWidth
        canvas.height = img.height * scale
        const ctx = canvas.getContext('2d')
        ctx?.drawImage(img, 0, 0, canvas.width, canvas.height)
        canvas.toBlob(
          (blob) => {
            if (blob) resolve(new File([blob], file.name, { type: 'image/jpeg', lastModified: Date.now() }))
            else reject(new Error('压缩失败'))
          },
          'image/jpeg',
          0.8
        )
      }
      img.onerror = reject
      img.src = e.target?.result as string
    }
    reader.onerror = reject
    reader.readAsDataURL(file)
  })
}

function onPreviewLoad() {
  detecting.value = true
  setTimeout(() => runAllDetections(), 500)
}

// 执行四项检测
async function runAllDetections() {
  if (!previewImageRef.value) return
  
  const canvas = document.createElement('canvas')
  const ctx = canvas.getContext('2d')
  const img = previewImageRef.value
  
  canvas.width = img.naturalWidth
  canvas.height = img.naturalHeight
  ctx?.drawImage(img, 0, 0)
  
  console.log('=== 开始四项检测 ===')
  
  // 检测1：清晰度
  const clarityResult = detectClarity(canvas)
  detectionResults.value.clarity = clarityResult
  console.log('检测1-清晰度:', clarityResult)
  
  // 检测2：角度
  const angleResult = detectAngle(canvas)
  detectionResults.value.angle = angleResult
  console.log('检测2-角度:', angleResult)
  
  // 检测3：文字内容
  const textResult = detectTextContent(canvas)
  detectionResults.value.text = textResult
  console.log('检测3-文字:', textResult)
  
  // 检测4：学习资料
  const materialResult = detectLearningMaterial(canvas)
  detectionResults.value.material = materialResult
  console.log('检测4-学习资料:', materialResult)
  
  detecting.value = false
  detectionCompleted.value = true
  
  console.log('=== 检测完成 ===', detectionResults.value)
  
  // 如果有问题，显示弹窗
  if (!allPassed.value) {
    showProblemDialog.value = true
  }
}

// 检测1：清晰度（拉普拉斯方差）
function detectClarity(canvas: HTMLCanvasElement): { pass: boolean; value: number } {
  const ctx = canvas.getContext('2d')
  if (!ctx) return { pass: true, value: 0 }
  
  const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height)
  const data = imageData.data
  const width = canvas.width
  const height = canvas.height
  
  // 转灰度
  const gray: number[] = []
  for (let i = 0; i < data.length; i += 4) {
    gray.push(0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2])
  }
  
  // Laplacian算子
  const laplacian = [0, 1, 0, 1, -4, 1, 0, 1, 0]
  let sum = 0
  let count = 0
  
  for (let y = 1; y < height - 1; y++) {
    for (let x = 1; x < width - 1; x++) {
      let val = 0
      for (let ky = -1; ky <= 1; ky++) {
        for (let kx = -1; kx <= 1; kx++) {
          val += gray[(y + ky) * width + (x + kx)] * laplacian[(ky + 1) * 3 + (kx + 1)]
        }
      }
      sum += val * val
      count++
    }
  }
  
  const variance = count > 0 ? sum / count : 0
  const pass = variance >= 100
  
  return { pass, value: variance }
}

// 检测2：角度（霍夫变换简化版）
function detectAngle(canvas: HTMLCanvasElement): { pass: boolean; value: number } {
  const ctx = canvas.getContext('2d')
  if (!ctx) return { pass: true, value: 0 }
  
  const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height)
  const data = imageData.data
  const width = canvas.width
  const height = canvas.height
  
  // 转灰度
  const gray: number[] = []
  for (let i = 0; i < data.length; i += 4) {
    gray.push(0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2])
  }
  
  // 简化边缘检测
  const edges: number[][] = []
  for (let y = 1; y < height - 1; y += 2) {
    for (let x = 1; x < width - 1; x += 2) {
      const gx = gray[(y-1)*width + (x+1)] - gray[(y-1)*width + (x-1)] +
                 2*(gray[y*width + (x+1)] - gray[y*width + (x-1)]) +
                 gray[(y+1)*width + (x+1)] - gray[(y+1)*width + (x-1)]
      const gy = gray[(y+1)*width + (x-1)] - gray[(y-1)*width + (x-1)] +
                 2*(gray[(y+1)*width + x] - gray[(y-1)*width + x]) +
                 gray[(y+1)*width + (x+1)] - gray[(y-1)*width + (x+1)]
      const edge = Math.sqrt(gx*gx + gy*gy)
      if (edge > 100) {
        edges.push([x, y])
      }
    }
  }
  
  if (edges.length < 10) return { pass: true, value: 0 }
  
  // 简化霍夫变换：找最长近似水平线
  let maxAngle = 0
  for (let i = 0; i < Math.min(100, edges.length); i++) {
    for (let j = i + 1; j < Math.min(100, edges.length); j++) {
      const [x1, y1] = edges[i]
      const [x2, y2] = edges[j]
      if (Math.abs(x2 - x1) > 50) {
        const angle = Math.atan2(y2 - y1, x2 - x1) * 180 / Math.PI
        if (Math.abs(angle) > Math.abs(maxAngle) && Math.abs(angle) < 45) {
          maxAngle = angle
        }
      }
    }
  }
  
  const pass = Math.abs(maxAngle) <= 10
  return { pass, value: maxAngle }
}

// 检测3：文字内容（滑动窗口扫描）
function detectTextContent(canvas: HTMLCanvasElement): { pass: boolean; value: number } {
  const ctx = canvas.getContext('2d')
  if (!ctx) return { pass: true, value: 0 }
  
  const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height)
  const data = imageData.data
  const width = canvas.width
  const height = canvas.height
  
  // 转灰度
  const gray: number[] = []
  for (let i = 0; i < data.length; i += 4) {
    gray.push(0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2])
  }
  
  // 滑动窗口检测文字区域
  const windowSize = 16
  let textRegions = 0
  
  for (let by = 0; by < height - windowSize; by += windowSize / 2) {
    for (let bx = 0; bx < width - windowSize; bx += windowSize / 2) {
      let darkCount = 0
      let lightCount = 0
      let edgeCount = 0
      
      for (let y = by; y < by + windowSize; y++) {
        for (let x = bx; x < bx + windowSize; x++) {
          const val = gray[y * width + x]
          if (val < 80) darkCount++
          else if (val > 200) lightCount++
          
          // 边缘检测
          if (x > 0 && x < width - 1) {
            const diff = Math.abs(gray[y * width + x] - gray[y * width + x + 1])
            if (diff > 50) edgeCount++
          }
        }
      }
      
      // 文字特征：深色文字+浅色背景+明显边缘
      const total = windowSize * windowSize
      const darkRatio = darkCount / total
      const lightRatio = lightCount / total
      const edgeRatio = edgeCount / total
      
      if (darkRatio > 0.1 && lightRatio > 0.3 && edgeRatio > 0.05) {
        textRegions++
      }
    }
  }
  
  const pass = textRegions >= 10
  return { pass, value: textRegions }
}

// 检测4：学习资料判断
function detectLearningMaterial(canvas: HTMLCanvasElement): { pass: boolean; value: number; whiteRatio: number; colorCount: number } {
  const ctx = canvas.getContext('2d')
  if (!ctx) return { pass: true, value: 0, whiteRatio: 0, colorCount: 0 }
  
  const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height)
  const data = imageData.data
  const totalPixels = data.length / 4
  
  // 统计白色像素和颜色种类
  let whitePixels = 0
  const colorMap = new Map<string, number>()
  
  for (let i = 0; i < data.length; i += 4) {
    const r = data[i]
    const g = data[i + 1]
    const b = data[i + 2]
    
    // 白色检测
    if (r > 200 && g > 200 && b > 200) whitePixels++
    
    // 颜色种类（量化到32级减少误差）
    const colorKey = `${Math.floor(r/32)}-${Math.floor(g/32)}-${Math.floor(b/32)}`
    colorMap.set(colorKey, (colorMap.get(colorKey) || 0) + 1)
  }
  
  const whiteRatio = whitePixels / totalPixels
  const colorCount = colorMap.size
  
  // 判断标准
  // 学习资料：白色占比 > 25% 且 颜色种类 < 15
  // 非学习资料：白色占比 < 15% 或 颜色种类 > 25
  const isNotLearningMaterial = (whiteRatio < 0.15 || colorCount > 25)
  
  const pass = !isNotLearningMaterial
  
  return { pass, value: pass ? 1 : 0, whiteRatio, colorCount }
}

function handleConfirmClick() {
  if (detecting.value) {
    showToast('请等待检测完成')
    return
  }
  
  if (!selectedFile.value) return
  
  emit('capture', selectedFile.value)
  closeCamera()
}

function confirmUsePhoto() {
  handleConfirmClick()
}

function retakePhoto() {
  resetState()
}

function closeCamera() {
  visible.value = false
}

watch(() => props.modelValue, (val) => {
  visible.value = val
  if (val) resetState()
  else resetState()
}, { immediate: true })

watch(visible, (val) => {
  emit('update:modelValue', val)
})
</script>

<style scoped lang="scss">
.a4-camera-guide {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  
  .camera-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    background: #fff;
    border-bottom: 1px solid #eee;
    
    .title {
      font-size: 17px;
      font-weight: 500;
    }
    
    .header-placeholder {
      width: 24px;
    }
  }
  
  .guide-instructions {
    padding: 20px;
    background: #fff;
    margin: 12px;
    border-radius: 8px;
    
    .instruction-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      color: #333;
      
      .van-icon {
        color: #1677ff;
      }
    }
  }
  
  .a4-guide-example {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    
    .a4-frame-example {
      width: 80%;
      max-width: 280px;
      aspect-ratio: 210 / 297;
      border: 2px dashed #ccc;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      
      .corner {
        position: absolute;
        width: 20px;
        height: 20px;
        border: 3px solid #1677ff;
      }
      
      .corner-tl { top: -2px; left: -2px; border-right: none; border-bottom: none; }
      .corner-tr { top: -2px; right: -2px; border-left: none; border-bottom: none; }
      .corner-bl { bottom: -2px; left: -2px; border-right: none; border-top: none; }
      .corner-br { bottom: -2px; right: -2px; border-left: none; border-top: none; }
      
      .a4-label {
        color: #999;
        font-size: 24px;
        font-weight: bold;
      }
    }
    
    .example-tip {
      margin-top: 16px;
      color: #666;
      font-size: 14px;
    }
  }
  
  .camera-controls {
    padding: 20px;
    background: #fff;
    
    .button-group {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    
    .photo-tip {
      margin-top: 12px;
      text-align: center;
      color: #999;
      font-size: 12px;
    }
  }
  
  .preview-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 16px;
    
    .a4-preview-wrapper {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: auto;
      
      .a4-frame-container {
        position: relative;
        max-width: 100%;
        max-height: 60vh;
        background: #fff;
        border-radius: 4px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.1);
        
        .preview-image {
          width: 100%;
          height: 100%;
          object-fit: contain;
          display: block;
        }
        
        .a4-frame-overlay {
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          pointer-events: none;
          
          .corner {
            position: absolute;
            width: 24px;
            height: 24px;
            border: 3px solid #1677ff;
          }
          
          .corner-tl { top: 0; left: 0; border-right: none; border-bottom: none; }
          .corner-tr { top: 0; right: 0; border-left: none; border-bottom: none; }
          .corner-bl { bottom: 0; left: 0; border-right: none; border-top: none; }
          .corner-br { bottom: 0; right: 0; border-left: none; border-top: none; }
          
          .a4-label {
            position: absolute;
            bottom: 8px;
            right: 8px;
            background: rgba(22, 119, 255, 0.9);
            color: #fff;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
          }
        }
        
        .detection-results {
          position: absolute;
          top: 8px;
          left: 8px;
          display: flex;
          flex-wrap: wrap;
          gap: 4px;
          
          .result-tag {
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 500;
            
            &.pass {
              background: #e6f7e6;
              color: #52c41a;
            }
            
            &.fail {
              background: #fff2f0;
              color: #ff4d4f;
            }
          }
        }
      }
    }
    
    .quality-status {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 16px;
      color: #666;
    }
    
    .preview-tips {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px;
      background: #fff8e6;
